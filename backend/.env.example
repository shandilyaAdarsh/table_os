# ============================================================
# Orderlli Backend — Environment Variables
# ============================================================
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT secret — must match Supabase project JWT secret
# Found in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Application ──────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# URL of the admin frontend — used for password reset redirect links
ADMIN_FRONTEND_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────

# Max failed logins before lockout (default: 5)
AUTH_MAX_FAILED_LOGINS=5

# Login attempt window in minutes (default: 15)
AUTH_RATE_WINDOW_MINUTES=15

# Lockout duration in minutes after max failures (default: 30)
AUTH_LOCKOUT_MINUTES=30

# ─── Session ──────────────────────────────────────────────────

# Standard session TTL in seconds (default: 3600 = 1 hour)
AUTH_ACCESS_TOKEN_TTL=3600

# Device session expiry: standard login (days)
AUTH_DEVICE_SESSION_TTL_DAYS=1

# Device session expiry: remember_me=true (days)
AUTH_DEVICE_SESSION_REMEMBER_ME_DAYS=30

# ─── QR / Device Security ────────────────────────────────────

# HMAC signing secret for QR code payloads
QR_SIGNING_SECRET=change-this-qr-signing-secret

# HMAC signing secret for QR session tokens
QR_SESSION_SECRET=change-this-qr-session-secret

# HMAC signing secret for device registration tokens
DEVICE_TOKEN_SECRET=change-this-device-token-secret
